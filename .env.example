# Copy to .env (gitignored) and fill in. Loaded automatically at startup.

# Claude API key. When set, Architect.IQ uses the LLM for requirement extraction,
# capability derivation, pattern matching, and image (vision) ingest. Without it,
# the engine falls back to deterministic heuristics and still runs fully.
ANTHROPIC_API_KEY=

# Optional: override the model used for LLM ingest/matching.
# ARCHITECTIQ_LLM_MODEL=claude-sonnet-5

# Optional: force the deterministic path even when a key is present (1/true/yes).
# ARCHITECTIQ_DISABLE_LLM=

# Optional: SQLite database path (default: architect_iq.db in the working dir).
# ARCHITECTIQ_DB=architect_iq.db

# Optional: allowed CORS origins for the API (comma-separated).
# ARCHITECTIQ_CORS=http://localhost:5173
